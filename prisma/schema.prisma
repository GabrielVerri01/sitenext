generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  usuario   String  
  email     String   @unique
  senha     String
  cargo     String
  resetToken       String?   @unique 
  resetTokenExpire DateTime? 
  createdAt DateTime @default(now())
}

model Produto {
  id           Int      @id @default(autoincrement())
  nome         String
  descricao    String
  preco        Float
  imagem       String
  ativo        Boolean  @default(true)

  variacoes    Variacao[]

  createdAt    DateTime @default(now())
}

model Variacao {
  id          Int     @id @default(autoincrement())
  tamanho     String  
  preco       Float
  estoque     Int 

  produtoId   Int 
  produto     Produto @relation(fields: [produtoId], references: [id])
}
